# Configurações do Banco de Dados PostgreSQL
DB_USER=eco_user
DB_PASSWORD=eco_password
DB_NAME=eco_db
DB_HOST=db
DB_PORT=5432

# URL de conexão que o Python vai usar
DB_URL=postgresql://eco_user:eco_password@db/eco_db

# Segurança do Back-end
SECRET_KEY=sua_chave_secreta_super_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30